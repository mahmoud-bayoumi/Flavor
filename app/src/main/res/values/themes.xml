<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.Flavor" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Make Android 12+ system splash fully transparent -->
        <item name="android:windowSplashScreenBackground">@android:color/transparent</item>
        <item name="android:windowSplashScreenAnimatedIcon">@null</item>
        <item name="android:windowSplashScreenAnimationDuration">0</item>
        <item name="postSplashScreenTheme">@style/Theme.Flavor</item>
    </style>

    <style name="CircleImage">
        <item name="cornerSize">50%</item>
    </style>

    <style name="RoundedImage">
        <item name="cornerSize">8dp</item>
    </style>


    <style name="Theme.Flavor" parent="Base.Theme.Flavor" />
</resources>
